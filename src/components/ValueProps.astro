---
// src/components/ValueProps.astro
---

<section class="valueprops">
  <div class="container valueprops__inner">
    <!-- Left: headline -->
    <div class="valueprops__heading">
      <h2>Add value to your customer relationships</h2>
    </div>

    <!-- Right: 2x2 icon grid -->
    <div class="valueprops__grid">
      <div class="vp-item">
        <div class="vp-item__icon">
          <svg
            viewBox="0 0 40 40"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M20 8a12 12 0 100 24A12 12 0 0020 8z"
              stroke="#2d4a8a"
              stroke-width="1.5"></path>
            <path
              d="M15 20h10M20 15v10"
              stroke="#2d4a8a"
              stroke-width="1.5"
              stroke-linecap="round"></path>
            <path
              d="M26 14l4-4M14 26l-4 4M26 26l4 4M14 14l-4-4"
              stroke="#2d4a8a"
              stroke-width="1.5"
              stroke-linecap="round"></path>
          </svg>
        </div>
        <p>Grow subscriber monetization & ARPU</p>
      </div>

      <div class="vp-item">
        <div class="vp-item__icon">
          <svg
            viewBox="0 0 40 40"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M20 32c6.627 0 12-5.373 12-12S26.627 8 20 8 8 13.373 8 20s5.373 12 12 12z"
              stroke="#2d4a8a"
              stroke-width="1.5"></path>
            <path
              d="M20 14v6l4 4"
              stroke="#2d4a8a"
              stroke-width="1.5"
              stroke-linecap="round"></path>
            <path
              d="M14 8l-4 4M26 8l4 4"
              stroke="#2d4a8a"
              stroke-width="1.5"
              stroke-linecap="round"></path>
          </svg>
        </div>
        <p>Expand your solutions portfolio</p>
      </div>

      <div class="vp-item">
        <div class="vp-item__icon">
          <svg
            viewBox="0 0 40 40"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M8 32l8-8 6 6 10-14"
              stroke="#2d4a8a"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
            <circle cx="30" cy="12" r="4" stroke="#2d4a8a" stroke-width="1.5"
            ></circle>
            <path
              d="M27 12l2 2 4-4"
              stroke="#2d4a8a"
              stroke-width="1.5"
              stroke-linecap="round"></path>
          </svg>
        </div>
        <p>Optimize your user experience</p>
      </div>

      <div class="vp-item">
        <div class="vp-item__icon">
          <svg
            viewBox="0 0 40 40"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <rect
              x="8"
              y="24"
              width="6"
              height="8"
              rx="1"
              stroke="#2d4a8a"
              stroke-width="1.5"></rect>
            <rect
              x="17"
              y="16"
              width="6"
              height="16"
              rx="1"
              stroke="#2d4a8a"
              stroke-width="1.5"></rect>
            <rect
              x="26"
              y="8"
              width="6"
              height="24"
              rx="1"
              stroke="#2d4a8a"
              stroke-width="1.5"></rect>
          </svg>
        </div>
        <p>Increase engagement & retention</p>
      </div>
    </div>
  </div>
</section>

<style>
  .valueprops {
    padding: 6rem 0;
    background: white;
  }

  .valueprops__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .valueprops__heading h2 {
    font-size: 2.75rem;
    font-weight: 800;
    color: var(--color-navy);
    line-height: 1.15;
  }

  .valueprops__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem 3rem;
  }

  .vp-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.75rem;
  }

  .vp-item__icon {
    width: 48px;
    height: 48px;
  }

  .vp-item__icon svg {
    width: 100%;
    height: 100%;
  }

  .vp-item p {
    font-size: 0.95rem;
    color: var(--color-navy);
    line-height: 1.5;
    max-width: 160px;
  }
</style>
