---
// src/components/Partners.astro
---

<section class="partners">
  <div class="container">
    <h2 class="partners__heading">
      Trusted by<br />top global partners
    </h2>

    <div class="partners__logos">
      <img
        src="https://stagessl.realdefen.se/content/uploads/2024/08/lenovo-logo-main-red.png"
        alt="Lenovo"
        class="partner-logo"
      />
      <img
        src="https://stagessl.realdefen.se/content/uploads/2025/09/yahoo-logo-purple-1280x355-1-1024x284.png"
        alt="Yahoo"
        class="partner-logo"
      />
      <img
        src="https://stagessl.realdefen.se/content/uploads/2024/08/image-261.png"
        alt="IONOS"
        class="partner-logo"
      />
      <img
        src="https://stagessl.realdefen.se/content/uploads/2025/09/dell-logo-300x94-1.png"
        alt="Dell"
        class="partner-logo"
      />
      <img
        src="https://stagessl.realdefen.se/content/uploads/2024/08/best-buy-seeklogo-1.png"
        alt="Best Buy"
        class="partner-logo"
      />
      <img
        src="https://stagessl.realdefen.se/content/uploads/2024/08/Frame.png"
        alt="Staples"
        class="partner-logo"
      />
      <img
        src="https://stagessl.realdefen.se/content/uploads/2025/09/capital-one-logo-blue-red-1798x625-1-1024x356.png"
        alt="Capital One"
        class="partner-logo"
      />
      <img
        src="https://stagessl.realdefen.se/content/uploads/2025/09/hp-circle-logo-blue-3000x3000-1-1024x1024.png"
        alt="HP"
        class="partner-logo"
      />
    </div>

    <div class="partners__cta">
      <a href="#" class="btn btn--primary">Partner with Us</a>
      <a href="#" class="btn btn--primary">Partner Case Studies</a>
    </div>
  </div>
</section>

<style>
  .partners {
    padding: 6rem 0;
    background: #f5f5f5;
    text-align: center;
  }

  .partners__heading {
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--color-navy);
    line-height: 1.2;
    margin-bottom: 3rem;
  }

  .partners__logos {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 2.5rem 3rem;
    margin-bottom: 3rem;
  }

  .partner-logo {
    height: 40px;
    width: auto;
    object-fit: contain;
    filter: none;
    opacity: 0.9;
  }

  .partner-logo:hover {
    opacity: 1;
  }

  .partners__cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-top: 2.5rem;
  }

  .btn--primary {
    display: inline-block;
    background: #2d4a8a;
    color: white;
    padding: 1rem 2rem;
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    border-radius: 4px;
  }

  .btn--primary:hover {
    background: var(--color-blue);
  }

  @media (max-width: 768px) {
    .partners__logos {
      gap: 1.5rem 2rem;
    }
    .partner-logo {
      height: 30px;
    }
    .partners__cta {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
